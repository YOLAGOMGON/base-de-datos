  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "pm.test(\"Respuesta JSON\", function () {",
              "  pm.response.to.be.json;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Crear cliente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laura\",\n  \"telefono\": \"555\",\n  \"ciudad\": \"Cali\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/clientes",
              "host": ["{{base_url}}"],
              "path": ["clientes"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", function () {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "pm.test(\"Tiene id_cliente\", function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property(\"id_cliente\");",
                  "});",
                  "pm.environment.set(\"cliente_id\", pm.response.json().id_cliente);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Listar clientes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/clientes",
              "host": ["{{base_url}}"],
              "path": ["clientes"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test(\"Es un arreglo\", function () {",
                  "  pm.expect(pm.response.json()).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Obtener cliente",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/clientes/{{cliente_id}}",
              "host": ["{{base_url}}"],
              "path": ["clientes", "{{cliente_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test(\"Tiene id_cliente\", function () {",
                  "  pm.expect(pm.response.json()).to.have.property(\"id_cliente\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Actualizar cliente",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laura Gomez\",\n  \"telefono\": \"555\",\n  \"ciudad\": \"Cali\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/clientes/{{cliente_id}}",
              "host": ["{{base_url}}"],
              "path": ["clientes", "{{cliente_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test(\"Nombre actualizado\", function () {",
                  "  pm.expect(pm.response.json().nombre).to.eql(\"Laura Gomez\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Eliminar cliente",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/clientes/{{cliente_id}}",
              "host": ["{{base_url}}"],
              "path": ["clientes", "{{cliente_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test(\"Mensaje eliminado\", function () {",
                  "  pm.expect(pm.response.json().message).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
